# Copy to .env (gitignored) for local `netlify dev`, and set the real values in
# Netlify dashboard → Site settings → Environment variables for production.
#
# IMPORTANT: only VITE_-prefixed vars are bundled into the client JS. The Turnstile
# *secret* and the webhook URL must stay UNPREFIXED so they never ship to the browser.

# --- Client (public, shipped in the bundle) ---
# Cloudflare Turnstile site key. Use the always-passing test key for local dev:
#   1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# --- Server only (Netlify Functions — never exposed to the browser) ---
# Cloudflare Turnstile secret key. Always-passing test secret for local dev:
#   1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=

# Make.com webhook the career form is forwarded to (was previously hardcoded in the client).
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xnwdxoukkmxdvrah4n8do2jq6bthp85t
